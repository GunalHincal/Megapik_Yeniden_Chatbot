{
  "version": 2,
  "functions": {
      "main.py": {
          "runtime": "python3.11"
      }
  },
  "routes": [
      {
          "src": "/(.*)",
          "dest": "main.py"
      }
  ],
  "build": {
      "env": {
          "PIP_NO_CACHE_DIR": "off"
      }
  },
  "env": {
      "GEMINI_API_KEY": "@gemini_api_key"
  }
}
