{
  "version": 2,
  "functions": {
      "main.py": {
          "runtime": "python@latest"
      }
  },
  "routes": [
      {
          "src": "/static/(.*)",
          "dest": "/static/$1"
      },
      {
          "src": "/(.*)",
          "dest": "main.py"
      }
  ],
  "build": {
      "commands": [
          "pip install -r requirements.txt",
          "python vector_store_api.py"       
      ]
  },
  "ignoreCommand": "echo 'Ignoring files...'",
  "env": {
      "PYTHONUNBUFFERED": "1"
  }
}
